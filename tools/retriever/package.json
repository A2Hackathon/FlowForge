{
  "name": "flowforge-retriever",
  "version": "1.0.0",
  "description": "Language-aware code retriever for FlowForge Duo flow",
  "main": "index.js",
  "scripts": {
    "index": "node index.js index --repo . --out ../retrieval",
    "retrieve": "node index.js retrieve --repo . --index ../retrieval/index.json --query \"summarize repo\" --out ../retrieval"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0"
  }
}
