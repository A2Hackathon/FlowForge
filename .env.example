# GitLab (required for CLI scan and Duo)
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_PROJECT_ID=

# GitLab OAuth (for Electron app login)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# GCP (optional; improves plan/pricing)
GCP_PROJECT_ID=
GCP_API_KEY=

# Claude / Anthropic (optional; GCP recommendations)
ANTHROPIC_API_KEY=

# Usage answers -> runFlow -> generateGcpPlan (CLI env)
USERS=1000
TEAM_SIZE=5
BUDGET=medium
IS_PROD=false
EXPECTS_SPIKES=false

# CLI file output (optional)
# WRITE_FILES=1
# OUTPUT_DIR=./artifacts
